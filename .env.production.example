# =============================================================================
# per0w.space Production — переменные окружения
#
# Скопировать на VPS: cp .env.production.example .env.production
# Заполнить все значения, затем запустить: ./deploy/deploy.sh
# =============================================================================

# ── Домен ─────────────────────────────────────────────────────────────
DOMAIN=per0w.space

# ── Email для Let's Encrypt SSL ──────────────────────────────────────
ACME_EMAIL=per0w@yandex.ru

# ── Форма «Связаться» (Web3Forms → письмо на per0w@yandex.ru) ───────────
# Ключ с https://web3forms.com (в кабинете указать тот же email получателя).
# Для статической сборки задать в CI / .env.local как NEXT_PUBLIC_*.
# NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Опционально: кнопка «AI» в форме контактов (Gemini). Ключ попадёт в бандл — ограничьте referrer в Google AI Studio.
# NEXT_PUBLIC_GEMINI_API_KEY=
